# WebSocket backend URL (dev default is ws://localhost:8082 if omitted)
VITE_WS_URL=ws://localhost:8082

# Snapshot debug in HUD/last message: true/false (or 1/0)
# Recommended: false in production
VITE_SHOW_SNAPSHOT_DEBUG=true

# Debug HUD visibility: true/false (or 1/0)
# Default if omitted: true in dev, false in production
VITE_SHOW_DEBUG_HUD=true
